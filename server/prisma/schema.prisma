generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  OWNER
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  passwordHash String
  role       Role     @default(CUSTOMER)
  name       String?
  phone      String?
  bakeryName String?  // только для владельцев
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  generations Generation[]
  orders      Order[]

  @@map("users")
}

model Catalog {
  id          String  @id @default(uuid())
  name        String
  description String?
  image       String? // URL изображения торта
  price       Decimal @db.Decimal(10, 2)
  composition String?
  kcal        Int?
  protein     Decimal? @db.Decimal(5, 2)
  fats        Decimal? @db.Decimal(5, 2)
  carbs       Decimal? @db.Decimal(5, 2)

  orderCatalog OrderCatalog[]

  @@map("catalog")
}

model Generation {
  id        String   @id @default(uuid())
  prompt    String
  image     String?  // URL сгенерированного изображения
  userId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("generations")
}

model Order {
  id        String   @id @default(uuid())
  userId    String
  design    String?  // описание дизайна или ссылка
  status    String   // "new", "in_progress", "completed", "cancelled" и т.д.
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderCatalog  OrderCatalog[]
  reviews       Review[]

  @@index([userId])
  @@map("orders")
}

model OrderCatalog {
  orderId   String
  catalogId String

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  catalog Catalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)

  @@id([orderId, catalogId])
  @@map("order_catalog")
}

model Review {
  id        String   @id @default(uuid())
  orderId   String
  mark      Int      // 1–5
  text      String?
  createdAt DateTime @default(now())

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  answers   Answer[]

  @@index([orderId])
  @@map("reviews")
}

model Answer {
  id        String   @id @default(uuid())
  reviewId  String
  text      String
  createdAt DateTime @default(now())

  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("answers")
}